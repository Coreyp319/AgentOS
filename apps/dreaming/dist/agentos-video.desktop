[Desktop Entry]
Type=Service
Name=AgentOS Video
Comment=Generate a local video from a prompt (type: video: <prompt>)
Icon=video-x-generic
X-KDE-ServiceTypes=Plasma/Runner
X-Plasma-API=DBus
X-Plasma-DBusRunner-Service=org.agentos.krunner.video
X-Plasma-DBusRunner-Path=/krunner
X-KDE-PluginInfo-Name=agentos_video
X-KDE-PluginInfo-Version=0.1
X-KDE-PluginInfo-EnabledByDefault=true
