# AgentOS — recommended Ollama configuration (see docs/adr/0002).
#
# Apply with:  systemctl edit ollama
# (add these under [Service] as Environment="KEY=VALUE" lines), then:
#   systemctl daemon-reload && systemctl restart ollama
#
# Rationale: hand model residency / concurrency / queueing to Ollama so agentosd
# does NOT reimplement a scheduler. agentosd only adds priority, metrics, and the
# VRAM-yield trigger on top.

# Allow at most TWO models resident at once on the 24GB GPU (default is 3).
# Raised 1→2 for anticipatory pre-warm (ADR-0045): Lucid warms its two SMALL beat models together on
# app-open — the VLM (qwen2.5vl:3b, ~3.2GB) + the narrator (MN-12B, ~8.7GB) ≈ 12GB, which co-reside
# comfortably under 24GB minus the ~1.5GB wallpaper. The original "ONE large model" caution still holds:
# two 17–21GB models would thrash, but Ollama is fit-aware (it evicts under pressure rather than OOMing),
# and the i2v lease force-evicts BOTH beat models before a heavy load (lucid_linear B1 / ADR-0015 §3), so
# the cap never stacks a big LLM on top of the ~17GB video. Keep at 1 if you do not run Lucid pre-warm.
OLLAMA_MAX_LOADED_MODELS=2

# Allow a couple of concurrent requests against the resident model.
# Default is 1 (a single in-flight request).
OLLAMA_NUM_PARALLEL=2

# Default idle timeout before a model unloads. agentosd overrides this per-request:
#   keep_alive=-1  pin a model resident (interactive priority)
#   keep_alive=0   evict immediately (hand VRAM back to graphics)
OLLAMA_KEEP_ALIVE=5m

# Ollama's own FIFO request queue depth (returns HTTP 503 on overflow).
# agentosd does NOT add a second queue (double-queue footgun) — it leans on this
# one and only injects priority ordering.
OLLAMA_MAX_QUEUE=512
