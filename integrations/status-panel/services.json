{
  "groups": ["AI core", "AgentOS substrate", "Ambient desktop", "Notifications", "Desktop QoL", "Dreaming"],
  "services": [
    { "id": "hermes-gateway",   "name": "Hermes agent",            "group": "AI core",            "scope": "user",   "unit": "hermes-gateway.service",                                  "desc": "Gateway daemon — kanban, cron, delegation, messaging" },
    { "id": "hermes-dashboard", "name": "Hermes web UI",           "group": "AI core",            "scope": "user",   "unit": "hermes-dashboard.service",   "url": "http://127.0.0.1:9119",   "health": "http://127.0.0.1:9119/",            "desc": "Config, sessions, kanban board" },
    { "id": "comfyui",          "name": "ComfyUI",                 "group": "AI core",            "scope": "user",   "kind": "on_demand", "unit": "comfyui.service",       "url": "http://127.0.0.1:8188",   "health": "http://127.0.0.1:8188/system_stats", "tailnet": false, "desc": "Dreaming backend — local video/image gen (coordinator-spawned on demand). Deliberately NOT tailnet-served (agentosd-remote.sh) — desktop-only door." },
    { "id": "ollama",           "name": "Ollama runtime",          "group": "AI core",            "scope": "system", "unit": "ollama.service",                                           "health": "http://127.0.0.1:11434/api/version", "desc": "Local model server" },
    { "id": "models",           "name": "Models (audit)",          "group": "AI core",            "scope": "user",   "unit": "agentos-models-panel.service", "url": "http://127.0.0.1:9124", "health": "http://127.0.0.1:9124/healthz", "desc": "Every model AgentOS uses, what it's for, and that it's local" },

    { "id": "aurora-agent",     "name": "Fleet → wallpaper feed",  "group": "AgentOS substrate",  "scope": "user",   "unit": "nimbus-aurora-agent.service",                              "desc": "agentosd feed → agent.json (wallpaper mood)" },
    { "id": "aurora-keyhole",   "name": "Keyhole tray feed",       "group": "AgentOS substrate",  "scope": "user",   "unit": "nimbus-aurora-keyhole.service",                            "desc": "agentosd keyhole → keyhole.json (tray instrument)" },
    { "id": "status-panel",     "name": "Status panel",            "group": "AgentOS substrate",  "scope": "user",   "unit": "agentos-status-panel.service", "url": "http://127.0.0.1:9123", "health": "http://127.0.0.1:9123/", "desc": "Boot-health front door — this panel (opens at login only when something needs attention)" },

    { "id": "wallpaper",        "name": "Reactive wallpaper",      "group": "Ambient desktop",    "scope": "user",   "kind": "task",  "match": "app-*hexen*wallpaper*@autostart.service",                 "desc": "Ray-traced Hexen wallpaper (launched at login)" },
    { "id": "aurora-audio",     "name": "Music reactivity",        "group": "Ambient desktop",    "scope": "user",   "unit": "nimbus-aurora-audio.service",                              "desc": "Audio monitor → FFT → state file" },
    { "id": "aurora-bridge",    "name": "Window reactivity",       "group": "Ambient desktop",    "scope": "user",   "unit": "nimbus-aurora-bridge.service",                             "desc": "Window-state reactivity bridge" },

    { "id": "swaync",           "name": "Notifications",           "group": "Notifications",      "scope": "user",   "unit": "swaync.service",                                           "desc": "swaync — the desktop's nervous system" },
    { "id": "swaync-scheme",    "name": "Notif. theme sync",       "group": "Notifications",      "scope": "user",   "kind": "watch", "unit": "swaync-apply-scheme.path",                                 "desc": "Re-theme swaync on colour-scheme change" },

    { "id": "appunify",         "name": "App-scheme unify",        "group": "Desktop QoL",        "scope": "user",   "kind": "watch", "unit": "nimbus-appunify-scheme.path",                              "desc": "Unify app colour scheme on change" },
    { "id": "quicklook",        "name": "Quick Look",              "group": "Desktop QoL",        "scope": "user",   "kind": "task",  "unit": "nimbus-quicklook-ensure.service",                          "desc": "Dolphin Quick Look integration" },
    { "id": "refine-icons",     "name": "Icon refine",             "group": "Desktop QoL",        "scope": "user",   "kind": "watch", "unit": "nimbus-refine-icons.path",                                 "desc": "Polish icons when the theme changes" },
    { "id": "theme-toggle",     "name": "Theme toggle",            "group": "Desktop QoL",        "scope": "user",   "kind": "watch", "unit": "nimbus-theme-toggle-button.path",                          "desc": "Light/dark toggle button watcher" },

    { "id": "dream",            "name": "Nightly dreaming",        "group": "Dreaming",           "scope": "user",   "kind": "watch", "unit": "nimbus-dream.timer",                                       "desc": "Compose a journey leg each night (23:30)" },
    { "id": "lucid",            "name": "Lucid (dream loop)",      "group": "Dreaming",           "scope": "user",   "unit": "agentos-lucid.service",      "url": "http://127.0.0.1:8765", "health": "http://127.0.0.1:8765/healthz", "desc": "Interactive dream loop — watch a clip, choose what happens next (spike, ADR-0015)" },
    { "id": "share-hub",        "name": "AgentOS Share",           "group": "Dreaming",           "scope": "user",   "unit": "agentos-share.service",      "url": "http://127.0.0.1:8770", "health": "http://127.0.0.1:8770/healthz", "desc": "Phone → box photo ingest — share a photo to start a dream (ADR-0027)" }
  ]
}
