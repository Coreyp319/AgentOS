# AgentOS Share — optional environment. Copy to ~/.config/agentos/share.env and `chmod 600`.
#
# Wires the on-box Hermes API key into the share hub's "Ask Hermes" (chat) door. This value
# NEVER leaves the box and is never sent to the phone — the hub holds it; the phone holds only
# the X-Share-Key (a different, lower-trust credential). Without it, the Hermes-chat door fails
# honestly ("Hermes chat isn't configured") instead of pretending to send.
#
# Find the value Hermes' own API server uses (its API_SERVER_KEY) and paste it here.
HERMES_API_KEY=

# Optional overrides (defaults shown):
# LUCID_SHARE_PORT=8770
# HERMES_MODEL=hermes-agent
# SHARE_EXTRA_ORIGINS=https://4090.tail096c29.ts.net:8770
# SHARE_INBOX_TTL=86400        # seconds a Claude-door proposal lives on disk before it self-expires
