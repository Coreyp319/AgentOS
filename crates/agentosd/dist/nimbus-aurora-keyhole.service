[Unit]
Description=AgentOS keyhole feed (lease/VRAM/residency/fleet → keyhole.json for the tray instrument, ADR-0012)
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/agentosd keyhole
Restart=on-failure
RestartSec=2
Nice=8

[Install]
WantedBy=graphical-session.target
